{
  "expo": {
    "name": "DispensIA",
    "slug": "dispensia",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dispensia",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dispensia.app",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dispensia.app",
      "adaptiveIcon": {
        "backgroundColor": "#0d0d0f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          },
          "iosAppGroupIdentifier": "group.com.dispensia.app",
          "iosShareExtensionName": "DispensIA Share",
          "iosShareExtensionBundleIdentifier": "com.dispensia.app.DispensIAShare",
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0d0f"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permetti a DispensIA di accedere alle foto per aggiungere un'immagine alla tua ricetta."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45fe0b74-c230-4c8a-9a80-c0faf484084b",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "DispensIAShare",
                  "bundleIdentifier": "com.dispensia.app.DispensIAShare",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.dispensia.app"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "drugorg",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/45fe0b74-c230-4c8a-9a80-c0faf484084b"
    }
  }
}
